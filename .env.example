# ─────────────────────────────────────────────────────────────────────────
# OpenLeads environment configuration
# Copy this file to `.env` and fill in your own values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────────

# ── Core lead engine (lead_engine.py) ──
# The engine needs NO API keys. It runs on free, public sources out of the box.
# (Nothing required here.)

# ── Optional: cold-email campaign companion (automation.py) ──

# OpenRouter API key — used only to draft email copy. Free models available.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-your-key-here"

# SMTP credentials for sending (any provider: PrivateEmail, Gmail, Zoho, etc.)
# These are read at send time and are NEVER stored or transmitted anywhere else.
PRIVATEMAIL_USER="you@yourdomain.com"
PRIVATEMAIL_PASS="your-mailbox-password"

# Optional: Apollo key, only if you want to blend in Apollo enrichment.
# OpenLeads does NOT require this.
APOLLO_API_KEY=""
