# ─────────────────────────────────────────────────────────────────────────
# OpenLeads environment configuration
# Copy this file to `.env` and fill in your own values. NEVER commit `.env`.
# Nothing here is required for the core lead engine — it runs at $0, keyless.
# ─────────────────────────────────────────────────────────────────────────

# ── Optional: smarter chat ──
# If set, the chat CLI can parse free-form natural language with a free LLM.
# Without it, the rule-based parser handles everything offline.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# ── Optional: higher GitHub rate limit ──
# The `github` source works keyless (60 req/hr). A token raises it to 5,000/hr.
GITHUB_TOKEN=""

# ── Optional: cold-email companion (`openleads campaign`) ──
# Drafting model (any OpenRouter model; free ones work).
OPENROUTER_MODEL="openai/gpt-oss-120b:free"

# Your sending mailbox (any provider: PrivateEmail, Gmail, Zoho, Fastmail, …).
# Read only at send time; never stored or transmitted elsewhere.
SMTP_USER="you@yourdomain.com"
SMTP_PASS="your-mailbox-password"
SMTP_HOST="mail.yourprovider.com"
SMTP_PORT="465"

# How you sign and who you represent (used to draft personalized copy).
SENDER_NAME="Your Name"
CAMPAIGN_ORG="Your Company"
CAMPAIGN_CONTEXT="One or two sentences on what you're reaching out about and why it's relevant."
CAMPAIGN_MAX="60"
